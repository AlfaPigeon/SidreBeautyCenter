---

const mapImage =
  "https://lh3.googleusercontent.com/aida-public/AB6AXuCD25nGkm9HwsKV0T6Ly7U82wFq1bKdnnwnGD-CjtGqlSrCFtGjVVT_lYyybuqFtWA-8nQp2dOv3AcNxwJtgNDzxnmSHvcfV9lItaDKmJ9EWh_vDgtbEchAMSyQfylubZXBYLdJIQgP0e4lAc7m_33rRRpa7rlJL07m83RLARBnrMmH_-FRNj_Yhl4tZKTq37YuECccu7D5Z0CLFhvRmvIxHNBYNT15nQ-AjfV0JAauO-1Qza_DWcOeV6H6GCKbw4_iSQdTe0GFrGM";

const address = "Yukarı Bahçelievler Mahallesi Aşkaabat Caddesi 17, Zil Kodu No:6 D:6 2.kat, 06490 Çankaya/Ankara";
const phone = "+905326577591";
const whatsappLink = `https://wa.me/${phone.replace(/\D/g, '')}?text=Merhaba,%20Sidre%20Beauty%20Center%20için%20randevu%20almak%20istiyorum.`;
---

<section class="py-section-padding-desktop bg-surface" id="contact">
  <div class="max-w-container-max mx-auto px-gutter">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      <!-- Contact Info & Map -->
      <div class="flex flex-col h-full reveal">
        <h2 class="text-headline-lg font-headline-lg text-primary-container mb-6">
          Yolculuğunuza Başlayın
        </h2>
        <p class="text-body-md font-body-md text-on-surface-variant mb-10">
          Konsiyerjlerimiz, size en uygun bakım protokolünü tasarlamanızda
          yardımcı olmak için hazır. Sakinlik vaktinizi ayırtmak için bizimle
          iletişime geçin.
        </p>
        <div class="space-y-6 mb-10">
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary mt-1" data-icon="location_on"
              >location_on</span
            >
            <div>
              <p class="text-label-caps font-label-caps text-primary-container mb-1">
                Konum
              </p>
              <p class="text-body-md font-body-md text-on-surface-variant">
                {address}
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary mt-1" data-icon="call"
              >call</span
            >
            <div>
              <p class="text-label-caps font-label-caps text-primary-container mb-1">
                Telefon
              </p>
              <p class="text-body-md font-body-md text-on-surface-variant">
                {phone}
              </p>
            </div>
          </div>
        </div>
        <div class="flex gap-4 mb-10">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#25D366] text-white text-label-caps font-label-caps px-6 py-3 rounded-lg hover:bg-[#20BA5B] transition-all hover:scale-105 active:scale-95 group"
          >
              <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    fill="currentColor"
    class="w-5 h-5"
  >
    <path d="M19.11 17.21c-.28-.14-1.65-.81-1.91-.91-.26-.09-.44-.14-.63.14-.19.28-.72.91-.89 1.1-.16.19-.33.21-.61.07-.28-.14-1.18-.43-2.24-1.38-.83-.74-1.39-1.66-1.55-1.94-.16-.28-.02-.43.12-.57.13-.13.28-.33.42-.49.14-.16.19-.28.28-.47.09-.19.05-.35-.02-.49-.07-.14-.63-1.52-.86-2.08-.23-.55-.46-.47-.63-.48h-.53c-.19 0-.49.07-.75.35-.26.28-.98.96-.98 2.34s1 2.71 1.14 2.9c.14.19 1.97 3.01 4.77 4.22.67.29 1.19.46 1.59.59.67.21 1.28.18 1.76.11.54-.08 1.65-.68 1.88-1.33.23-.65.23-1.21.16-1.33-.07-.12-.26-.19-.53-.33z"/>
  </svg>
            WhatsApp'tan Randevu Al
          </a>
        </div>

      </div>

  
    </div>
  </div>
</section>
